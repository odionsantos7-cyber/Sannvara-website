# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MEDIUM_USERNAME: The Medium username to fetch articles from.
MEDIUM_USERNAME="@sannvara"

# SMTP Mail Server Configuration (Optional for notifications)
# Configure these to receive automated alerts for inquiries & newsletter signups.
# SMTP_SERVICE="gmail" # Optional: e.g. "gmail", "outlook" (takes precedence over SMTP_HOST)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE="false"
SMTP_USER="example@gmail.com"
SMTP_PASS="your_app_password"

# REST HTTP Email API Configurations (Highly Recommended to bypass Cloud Run/sandbox SMTP port blocks)
# Set either of these to send emails reliably over Port 443 (HTTP APIs are never blocked).
RESEND_API_KEY="re_YourResendApiKey"
SENDGRID_API_KEY="SG.YourSendGridApiKey"

